      <!-- ════════════════════════════════════════════════════════════════
           SECCIÓN 1: Resumen (anillo + meta) | Áreas (barras)
           Mobile: apilado. Desktop: 2 columnas.
           id="sec-resumen" en el wrapper de esta sección.
      ════════════════════════════════════════════════════════════════════ -->
      <div id="sec-resumen"
           class="fade-up lg:grid lg:grid-cols-2 lg:gap-12 lg:items-start mt-6 mb-8 lg:mb-10">

        <!-- ── Col izq: anillo + meta ── -->
        <div class="flex flex-col items-center sm:flex-row sm:items-start
                    lg:flex-col lg:items-center
                    gap-6 mb-8 lg:mb-0 lg:py-4">

          <!-- Anillo SVG del score -->
          <div id="score-ring-wrap" class="relative flex-shrink-0 w-[152px] h-[152px]">
            <svg width="152" height="152" viewBox="0 0 120 120" fill="none">
              <circle cx="60" cy="60" r="50"
