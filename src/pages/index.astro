    </nav>

    <!-- ── Contenido principal ── -->
    <!-- pb-24: espacio para la barra flotante en mobile -->
    <div class="max-w-[720px] lg:max-w-[1100px] mx-auto px-4 sm:px-6 pb-24 sm:pb-12">

      <!-- ════════════════════════════════════════════════════════════════
           SECCIÓN 1: Resumen (anillo + meta) | Áreas (barras)
           Mobile: apilado. Desktop: 2 columnas.
           id="sec-resumen" en el wrapper de esta sección.
