                    box-shadow: 0 24px 64px rgba(91,61,245,0.38), 0 4px 16px rgba(91,61,245,0.22);">

          <!-- Círculos decorativos de fondo -->
          <div style="position:absolute;top:-60px;right:-60px;width:220px;height:220px;
                      border-radius:999px;background:rgba(255,255,255,0.06);pointer-events:none;"></div>
          <div style="position:absolute;bottom:-80px;left:-40px;width:260px;height:260px;
                      border-radius:999px;background:rgba(255,255,255,0.04);pointer-events:none;"></div>

          <div class="relative z-10">
            <!-- Pregunta directa al dueño -->
            <p class="text-[13px] font-semibold mb-3"
               style="color:rgba(196,181,253,0.9);">
              ¿Querés que te ayudemos a mejorar esto?
            </p>

            <!-- Heading dinámico — renderizado por JS -->
            <h3 id="agenda-heading"
                class="text-2xl sm:text-3xl font-black leading-tight mb-3"
                style="color:#ffffff;">
              Estas oportunidades se pueden trabajar
            </h3>

            <!-- Cuerpo dinámico — renderizado por JS -->
            <p id="agenda-body"
               class="text-sm leading-relaxed mb-7 max-w-lg"
