            class="inline-flex items-center justify-center gap-2.5
                   bg-orange-500 hover:bg-orange-400 active:scale-[0.98]
                   text-white font-bold px-8 py-4 rounded-2xl
                   transition-all duration-150 text-[15px]
                   shadow-2xl shadow-orange-500/30 hover:shadow-orange-500/50
                   hover:-translate-y-0.5 w-full sm:w-auto"
          >
            Agendá gratis con los especialistas de Zimba
            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
