      <div id="sec-oportunidades" class="mb-10">
        <h3 class="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-1">
          Las 3 oportunidades prioritarias
        </h3>
        <p class="text-gray-400 text-xs mb-6">
          Hallazgos concretos de tu presencia digital, ordenados por impacto potencial
        </p>
        <div class="space-y-4 lg:grid lg:grid-cols-3 lg:gap-5 lg:space-y-0"
             id="oportunidades-container">
