  <!-- ═══════════════════════════════════════════════════════════════════════
       JAVASCRIPT — State machine + API + Rendering
  ═══════════════════════════════════════════════════════════════════════════ -->
  <script>
    'use strict';

    // ── Estado global ──────────────────────────────────────────────────────
    let currentUrl     = '';
    let currentEmpresa = '';

    // Deriva el nombre de empresa del dominio si el usuario no lo ingresó
    function displayCompanyName(empresa, url) {
      if (empresa && empresa.trim()) return empresa.trim();
      try {
        const hostname = new URL(url.startsWith('http') ? url : `https://${url}`).hostname;
        const raw = hostname.replace(/^www\./, '').split('.')[0].replace(/-/g, ' ');
        return raw.charAt(0).toUpperCase() + raw.slice(1);
      } catch { return url; }
    }

    function formatDate() {
      return new Date().toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
    }

    // ── Utilidades de pantalla ─────────────────────────────────────────────
    function showScreen(id) {
      document.querySelectorAll('.screen').forEach(s => s.classList.add('hidden'));
      const target = document.getElementById(`screen-${id}`);
      target.classList.remove('hidden');
      // Reiniciar animación de entrada
      target.querySelectorAll('.fade-up').forEach(el => {
        el.style.animation = 'none';
        // Forzar reflow para reiniciar la animación
        void el.offsetHeight;
        el.style.animation = '';
      });
      window.scrollTo({ top: 0, behavior: 'instant' });
      // Sticky CTA: solo visible en pantalla de resultados
      const stickyCta = document.getElementById('sticky-cta');
      if (stickyCta) stickyCta.classList.toggle('cta-hidden', id !== 'results');
    }

    // ── Validación de URL ──────────────────────────────────────────────────
    function isValidUrl(str) {
      if (!str || !str.includes('.')) return false;
      try {
        new URL(str.startsWith('http') ? str : `https://${str}`);
        return true;
      } catch {
        return false;
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // PANTALLA 1 → 2
    // ────────────────────────────────────────────────────────────────────────
    document.getElementById('btn-analizar').addEventListener('click', () => {
      const urlInput = document.getElementById('landing-url');
      const errEl = document.getElementById('landing-error');
      const val = urlInput.value.trim();

      if (!isValidUrl(val)) {
        errEl.classList.remove('hidden');
        urlInput.focus();
        return;
      }
      errEl.classList.add('hidden');
      currentUrl = val;
      document.getElementById('form-url-display').textContent = val;
      showScreen('form');
    });

    // Enter en el input de URL
    document.getElementById('landing-url').addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('btn-analizar').click();
    });

    document.getElementById('btn-back-landing').addEventListener('click', () => showScreen('landing'));

    // ────────────────────────────────────────────────────────────────────────
    // VALIDACIÓN DE FORMULARIO
    // ────────────────────────────────────────────────────────────────────────

    // Regex RFC-5322 simplificado: requiere algo@dominio.ext (al menos 1 char de extensión)
    function isValidEmail(v) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v.trim());
    }

    /**
     * Valida un campo y aplica estilos + muestra/oculta su mensaje de error.
     * Retorna true si es válido.
     */
    function validateField(input, isValid) {
      const wrapper = input.closest('div');
      const errMsg  = wrapper.parentElement.querySelector('.field-error');
      const okIcon  = wrapper.querySelector('.field-ok');

      input.classList.toggle('is-invalid', !isValid);
      input.classList.toggle('is-valid',    isValid);
      if (errMsg) errMsg.classList.toggle('hidden', isValid);
      if (okIcon) okIcon.classList.toggle('hidden',  !isValid);

      return isValid;
    }

    // Live check en email: mostrar check verde mientras el usuario escribe
    document.getElementById('input-email').addEventListener('input', function () {
      const val = this.value.trim();
      if (!val) {
        // Vacío: volver al estado neutro (sin error ni check)
        this.classList.remove('is-invalid', 'is-valid');
        const wrapper = this.closest('div');
        wrapper.querySelector('.field-ok').classList.add('hidden');
        wrapper.parentElement.querySelector('.field-error').classList.add('hidden');
      } else if (isValidEmail(val)) {
        validateField(this, true);
      } else {
        // Mientras escribe y el formato todavía no es válido: no mostrar error
        // hasta que pierda el foco (blur), para no molestar mientras tipea
        this.classList.remove('is-invalid', 'is-valid');
        const wrapper = this.closest('div');
        wrapper.querySelector('.field-ok').classList.add('hidden');
        wrapper.parentElement.querySelector('.field-error').classList.add('hidden');
      }
    });

    // Al salir del campo email sin valor válido: mostrar el error
    document.getElementById('input-email').addEventListener('blur', function () {
      const val = this.value.trim();
      if (val) validateField(this, isValidEmail(val));
    });

    // ────────────────────────────────────────────────────────────────────────
    // PANTALLA 2 → 3: envío del form
    // ────────────────────────────────────────────────────────────────────────
    document.getElementById('lead-form').addEventListener('submit', async e => {
      e.preventDefault();

      const nombreInput  = document.getElementById('input-nombre');
      const emailInput   = document.getElementById('input-email');
      const empresaInput = document.getElementById('input-empresa');

      const nombre  = nombreInput.value.trim();
      const email   = emailInput.value.trim();
      const empresa = empresaInput.value.trim();

      // Validar cada campo individualmente para mostrar errores específicos
      const v1 = validateField(nombreInput,  nombre.length >= 2);
      const v2 = validateField(emailInput,   isValidEmail(email));
      const v3 = validateField(empresaInput, empresa.length >= 2);

      if (!v1 || !v2 || !v3) {
        // Enfocar el primer campo inválido
        if (!v1) nombreInput.focus();
        else if (!v2) emailInput.focus();
        else empresaInput.focus();
        return;
      }

      currentEmpresa = empresa;
      showScreen('loading');
      resetSteps();

      await runAnalysis({ url: currentUrl, nombre, email, empresa });
    });

    // ────────────────────────────────────────────────────────────────────────
    // LOADING STEPS
    // ────────────────────────────────────────────────────────────────────────
    function resetSteps() {
      document.getElementById('loading-error').classList.add('hidden');
      for (let i = 1; i <= 4; i++) setStep(i, 'pending');
    }

    /** state: 'pending' | 'active' | 'done' */
    function setStep(n, state) {
      const el = document.getElementById(`step-${n}`);
      const pending = el.querySelector('.step-pending');
      const active  = el.querySelector('.step-active');
      const done    = el.querySelector('.step-done');

      // Reset classes
      [pending, active, done].forEach(x => x.classList.add('hidden'));
      el.classList.remove(
        'border-violet-300', 'bg-violet-50',
        'border-emerald-200', 'bg-emerald-50'
      );

      if (state === 'pending') {
        pending.classList.remove('hidden');
      } else if (state === 'active') {
        active.classList.remove('hidden');
        el.classList.add('border-violet-300', 'bg-violet-50');
      } else if (state === 'done') {
        done.classList.remove('hidden');
        el.classList.add('border-emerald-200', 'bg-emerald-50');
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // LLAMADA A LA API con lectura de SSE
    // ────────────────────────────────────────────────────────────────────────
    async function runAnalysis(data) {
      try {
        const res = await fetch('/api/analyze', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!res.ok || !res.body) {
          throw new Error(`El servidor respondió con error ${res.status}.`);
        }

        const reader  = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });

          // SSE: los mensajes están separados por \n\n
          const parts = buffer.split('\n\n');
          buffer = parts.pop(); // último fragmento incompleto, lo guardamos

          for (const part of parts) {
            if (!part.trim()) continue;

            let eventType = 'message';
            let eventData = '';

            for (const line of part.split('\n')) {
              if (line.startsWith('event: ')) eventType = line.slice(7).trim();
              if (line.startsWith('data: '))  eventData = line.slice(6).trim();
            }

            if (!eventData) continue;

            try {
              handleEvent(eventType, JSON.parse(eventData));
            } catch {
              console.warn('[SSE] No se pudo parsear:', eventData);
            }
          }
        }
      } catch (err) {
        showLoadingError(err.message ?? 'Error de conexión. Verificá tu internet.');
      }
    }

    function handleEvent(type, data) {
      if (type === 'progress') {
        // Marcar pasos anteriores como done, el actual como active
        for (let i = 1; i < data.step; i++) setStep(i, 'done');
        setStep(data.step, 'active');

      } else if (type === 'result') {
        // Completar todos los pasos y mostrar resultados
        for (let i = 1; i <= 4; i++) setStep(i, 'done');
        // Pequeña pausa para que el usuario vea el ✓ del último paso
        setTimeout(() => renderResults(data), 700);

      } else if (type === 'error') {
        showLoadingError(data.message ?? 'Error desconocido.');
      }
    }

    function showLoadingError(msg) {
      document.getElementById('loading-error').classList.remove('hidden');
      document.getElementById('loading-error-msg').textContent = msg;
    }

    document.getElementById('btn-retry').addEventListener('click', () => showScreen('landing'));

    // ────────────────────────────────────────────────────────────────────────
    // RENDERIZADO DE RESULTADOS
    // ────────────────────────────────────────────────────────────────────────
    function renderResults(data) {
      // ── Debug: verificar que areaExplicaciones llega del análisis ──────────
      console.log('[Debug] areaExplicaciones:', JSON.stringify(data.areaExplicaciones ?? null));

      // ── Counts globales (usados por veredicto, resumen y agenda) ────────────
      const allScores  = Object.values(data.scores ?? {});
      const critCount  = allScores.filter(s => s <= 8).length;
      const mejCount   = allScores.filter(s => s >= 9 && s <= 13).length;
      const bienCount  = allScores.filter(s => s >= 14).length;

      // ── Encabezado del informe ─────────────────────────────────────────────
      const companyName = displayCompanyName(currentEmpresa, currentUrl);
      document.getElementById('result-company-name').textContent = companyName;
      document.getElementById('result-meta').textContent =
        `${currentUrl} · ${formatDate()}`;

      // URL y número
      document.getElementById('result-url').textContent = currentUrl;
      document.getElementById('result-score').textContent = data.growthScore;

      // ── SVG Ring: animamos dashoffset y color según score ───────────────
      // Circunferencia = 2π × r(50) = 314.159
      const CIRC = 314.159;
      const arc  = document.getElementById('score-arc');
      const targetOffset = CIRC * (1 - data.growthScore / 100);
      // Necesitamos dos rAF para que la transición CSS sea visible
      // (el browser debe pintar el estado inicial dashoffset=CIRC primero)
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          arc.style.strokeDashoffset = targetOffset;
          arc.style.stroke = scoreColor(data.growthScore);
          document.getElementById('score-ring-wrap').style.filter =
            `drop-shadow(0 0 16px ${scoreGlow(data.growthScore)})`;
        });
      });

      // ── Badge de nivel ────────────────────────────────────────────────────
      const badge = document.getElementById('result-score-badge');
      const { text, cls } = scoreBadge(data.growthScore);
      badge.textContent = text;
      badge.className = `inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold border ${cls}`;

      // ── Mini resumen bajo el anillo ───────────────────────────────────────
      const summaryEl = document.getElementById('score-summary');
      if (summaryEl && data.scores) {
        const parts = [];
        if (critCount > 0) parts.push(`<span style="color:#dc2626;font-weight:700;">${critCount} crítica${critCount > 1 ? 's' : ''}</span>`);
        if (mejCount  > 0) parts.push(`<span style="color:#d97706;font-weight:700;">${mejCount} mejorable${mejCount > 1 ? 's' : ''}</span>`);
        if (bienCount > 0) parts.push(`<span style="color:#059669;font-weight:700;">${bienCount} bien</span>`);

        const summaryLine = parts.length > 0
          ? `Tenés ${parts.join(', ')} de las 5 áreas.`
          : '';

        // Top oportunidad (primera del array)
        const topOp = (data.oportunidades ?? [])[0];
        const topOpHtml = topOp
          ? `<p class="text-[12px] text-gray-500 mt-2 leading-snug border-t border-violet-100 pt-2">
               <span class="text-gray-700 font-semibold">Prioridad:</span> ${escHtml(topOp.titulo)}
             </p>`
          : '';

        summaryEl.innerHTML = `
          <div class="bg-violet-50 border border-violet-100 rounded-xl px-4 py-3 text-[13px] text-gray-600 leading-snug">
            ${summaryLine}
            ${topOpHtml}
          </div>`;
        summaryEl.classList.remove('hidden');
      }

      // ── Sub-scores con objetivo de referencia ────────────────────────────
      // TARGET: 17/20 = nivel de empresa que escala bien (85% de la barra)
      const TARGET     = 17;
      const TARGET_PCT = Math.round((TARGET / 20) * 100); // 85

      const subDefs = [
        { key: 'seo',           label: 'Posicionamiento en Google', icon: '🔍' },
        { key: 'paidReadiness', label: 'Preparación para publicidad', icon: '💰' },
        { key: 'cro',           label: 'Conversión de visitas',       icon: '🎯' },
        { key: 'tracking',      label: 'Medición de resultados',      icon: '📊' },
        { key: 'mensaje',       label: 'Claridad del mensaje',        icon: '✍️'  },
      ];

      const subContainer = document.getElementById('subscores-container');
      subContainer.innerHTML = subDefs.map(({ key, label, icon }) => {
        const score   = data.scores?.[key] ?? 0;
        const pct     = Math.round((score / 20) * 100);
        const gap     = TARGET - score;
        const isLarge = gap >= 5; // brecha grande = oportunidad destacada

        // Umbrales sobre 20: rojo 0-8, naranja 9-13, verde 14-20
        const isRed    = score <= 8;
        const isAmber  = score >= 9 && score <= 13;
        const isGreen  = score >= 14;

        const barHex = isGreen ? '#10b981' : isAmber ? '#f59e0b' : '#ef4444';
        const numCls = isGreen ? 'text-emerald-700' : isAmber ? 'text-amber-700' : 'text-red-600';

        // Texto de brecha debajo de la barra
        const gapText = score >= TARGET
          ? `<span style="font-size:11px;color:#059669;">En el nivel objetivo</span>`
          : `<span style="font-size:11px;color:#9ca3af;">Estás en ${score} · el objetivo es ${TARGET}/20</span>`;

        // Chip de estado
        const statusChip = isRed
          ? `<span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;padding:2px 8px;border-radius:999px;background:#fef2f2;color:#dc2626;border:1px solid #fecaca;">Crítico</span>`
          : isAmber
          ? `<span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;padding:2px 8px;border-radius:999px;background:#fffbeb;color:#d97706;border:1px solid #fde68a;">Mejorable</span>`
          : `<span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;padding:2px 8px;border-radius:999px;background:#f0fdf4;color:#059669;border:1px solid #bbf7d0;">Bien</span>`;

        // Explicaciones en criollo del área (vienen de Claude)
        const explicacion    = data.areaExplicaciones?.[key] ?? {};
        const queSignifica   = explicacion.queSignifica ?? '';
        const queCuesta      = explicacion.queCuesta    ?? '';
        const queCuestaColor = isRed ? '#dc2626' : isAmber ? '#d97706' : '#059669';
        const explicacionInner = (queSignifica || queCuesta)
          ? `${queSignifica ? `<p style="font-size:13px;color:#4b5563;line-height:1.5;margin:0 0 6px;">${escHtml(queSignifica)}</p>` : ''}
             ${queCuesta    ? `<p style="font-size:13px;color:${queCuestaColor};line-height:1.5;margin:0;">${escHtml(queCuesta)}</p>`    : ''}`
          : '';

        // Auto-expandir solo áreas críticas (rojo); las demás, colapsadas
        const openAttr = isRed ? 'open' : '';

        return `
          <details class="area-card rounded-xl overflow-hidden" ${openAttr}
                   style="border:1px solid ${isRed ? '#fecaca' : '#e5e7eb'}; background:#ffffff;">
            <summary class="px-4 pt-3.5 pb-3 flex flex-col gap-2.5">
              <!-- Fila: ícono + nombre + chip + score + chevron -->
              <div class="flex items-center justify-between gap-2">
                <span style="font-size:14px;color:#374151;display:flex;align-items:center;gap:8px;">
                  <span style="font-size:16px;line-height:1;">${icon}</span>${escHtml(label)}
                </span>
                <div class="flex items-center gap-2 flex-shrink-0">
                  ${statusChip}
                  <span style="font-size:14px;font-weight:700;" class="${numCls}">
                    ${score}<span style="font-size:11px;color:#9ca3af;font-weight:400;">/20</span>
                  </span>
                  <svg class="area-chevron" style="width:14px;height:14px;color:#9ca3af;flex-shrink:0;"
                       fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </div>
              </div>
              <!-- Barra -->
              <div class="relative" style="padding:3px 0;">
                <div style="height:6px;background:#f3f4f6;border-radius:999px;overflow:hidden;">
                  <div class="score-bar" style="height:100%;border-radius:999px;width:0%;background-color:${barHex};"
                       data-target="${pct}"></div>
                </div>
                <div style="position:absolute;top:50%;transform:translateY(-50%);width:2px;height:12px;border-radius:2px;background:#d1d5db;pointer-events:none;left:${TARGET_PCT}%;"
                     title="Objetivo: ${TARGET}/20"></div>
              </div>
              <!-- Brecha + hint -->
              <div class="flex items-center justify-between" style="margin-top:-4px;">
                ${gapText}
                <span class="area-expand-hint" style="font-size:10px;color:#d1d5db;">ver más ↓</span>
              </div>
            </summary>
            ${explicacionInner ? `
            <div style="padding:12px 16px 14px;border-top:1px solid #f3f4f6;">
              ${explicacionInner}
            </div>` : ''}
          </details>
        `;
      }).join('');

      // ── Tarjetas de oportunidades ─────────────────────────────────────────
      const opContainer = document.getElementById('oportunidades-container');
      opContainer.innerHTML = (data.oportunidades ?? []).slice(0, 3).map((op, i) => {
        const num = String(i + 1).padStart(2, '0');
        return `
          <div class="bg-white border border-gray-100
                      hover:border-violet-200 hover:bg-violet-50/30
                      rounded-2xl p-5 sm:p-6 transition-all duration-200 shadow-sm">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-11 h-11 rounded-xl
                          bg-violet-100 border border-violet-200
                          flex items-center justify-center">
                <span class="text-violet-600 font-black text-lg leading-none">${num}</span>
              </div>
              <div class="flex-1 min-w-0 pt-0.5">
                <h4 class="font-bold text-[#1e1b4b] text-[15px] mb-2 leading-snug">
                  ${escHtml(op.titulo ?? '')}
                </h4>
                <p class="text-gray-600 text-sm leading-relaxed">
                  ${escHtml(op.detalle ?? '')}
                </p>
              </div>
            </div>
          </div>
        `;
      }).join('');

      // ── Bloque de cierre dinámico ─────────────────────────────────────────
      // weakCount = áreas que necesitan atención (rojo + naranja)
      const weakCount = critCount + mejCount;
      const agendaHeading = document.getElementById('agenda-heading');
      const agendaBody    = document.getElementById('agenda-body');
      if (agendaHeading && agendaBody) {
        // Los <strong> usan inline style (fondo violeta oscuro, no Tailwind)
        if (weakCount >= 3) {
          agendaHeading.textContent = 'Estas oportunidades se pueden trabajar';
          agendaBody.innerHTML =
            `Tu presencia digital tiene <strong style="color:#fff;font-weight:800;">${weakCount} áreas con margen de mejora</strong>. ` +
            `En una reunión de 20 minutos te mostramos por dónde empezar y cómo priorizarlas ` +
            `para conseguir más clientes — sin compromiso.`;
        } else if (weakCount >= 1) {
          agendaHeading.textContent = 'Hay margen para crecer';
          agendaBody.innerHTML =
            `Detectamos <strong style="color:#fff;font-weight:800;">${weakCount} área${weakCount > 1 ? 's' : ''} con margen de mejora</strong> ` +
            `en tu presencia digital. En 20 minutos te explicamos cómo trabajarlas ` +
            `para convertirlas en más clientes — sin compromiso.`;
        } else {
          agendaHeading.textContent = 'Tu presencia digital está en buen nivel';
          agendaBody.innerHTML =
            `Ya estás bien posicionado. En una reunión de 20 minutos te mostramos ` +
            `cómo llevar cada área al tope y qué acciones generan mayor retorno ahora mismo.`;
        }
      }

      showScreen('results');

      // Animar barras DESPUÉS del primer frame pintado
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.querySelectorAll('.score-bar[data-target]').forEach(bar => {
            bar.style.width = bar.dataset.target + '%';
          });
        });
      });
    }

    /** Color del arco SVG según score global */
    function scoreColor(score) {
      if (score >= 71) return '#22c55e'; // verde
      if (score >= 41) return '#f97316'; // naranja
      return '#ef4444';                  // rojo
    }

    /** Glow del drop-shadow alrededor del anillo */
    function scoreGlow(score) {
      if (score >= 71) return 'rgba(5,150,105,0.18)';
      if (score >= 41) return 'rgba(217,119,6,0.18)';
      return 'rgba(220,38,38,0.18)';
    }

    function scoreBadge(score) {
      if (score >= 71) return { text: '✓ Buen rendimiento',         cls: 'bg-emerald-50 text-emerald-700 border-emerald-200' };
      if (score >= 41) return { text: '↑ Alto potencial de mejora', cls: 'bg-amber-50   text-amber-700   border-amber-200'   };
      return                   { text: '! Oportunidades urgentes',  cls: 'bg-red-50     text-red-600     border-red-200'     };
    }

    // Sanitización básica para prevenir XSS en el HTML renderizado
    function escHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    // Reiniciar todo desde cero
    document.getElementById('btn-restart').addEventListener('click', () => {
      document.getElementById('landing-url').value = '';
      showScreen('landing');
    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════════
       STICKY CTA — solo visible en pantalla de resultados
       Mobile: barra full-width fija abajo.
       Desktop: píldora centrada con sombra flotante.
  ═══════════════════════════════════════════════════════════════════════════ -->
  <div id="sticky-cta" class="cta-hidden fixed bottom-0 left-0 right-0 z-40 pointer-events-none">
    <!-- Fondo degradado que separa visualmente el botón del contenido -->
    <div class="pointer-events-none"
         style="background: linear-gradient(to top, rgba(248,247,255,0.96) 60%, transparent 100%);
                padding: 16px 16px 20px;">
      <div class="flex justify-center pointer-events-auto">
        <a href="https://cal.com/tomas-zimba/30min"
           target="_blank"
           rel="noopener"
           class="flex sm:inline-flex items-center justify-center gap-2.5
                  font-bold text-white text-sm sm:text-[15px]
                  rounded-2xl transition-all duration-150
                  w-full sm:w-auto
                  hover:-translate-y-0.5 hover:brightness-110 active:scale-[0.98]"
           style="background:#5b3df5;
                  padding:16px 28px;
                  box-shadow:0 8px 28px rgba(91,61,245,0.40), 0 2px 8px rgba(91,61,245,0.25);">
          Agendá gratis con los especialistas de Zimba
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

</body>
</html>
