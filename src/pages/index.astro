      <div id="sec-agenda" class="pb-6">

        <!-- Bloque de cierre — conecta el diagnóstico con la reunión -->
        <div class="bg-[#0C1220] border border-slate-700/50 rounded-2xl p-6 sm:p-8 mb-6">

          <!-- Encabezado dinámico — renderizado por JS en #agenda-heading -->
          <p class="text-[11px] font-bold uppercase tracking-widest text-orange-400/80 mb-3">
            Siguiente paso
          </p>
