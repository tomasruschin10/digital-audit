          <!-- Meta del score -->
          <div class="text-center sm:text-left lg:text-center">
            <p class="text-[11px] font-bold uppercase tracking-widest text-slate-500 mb-2">
              Growth Score
            </p>
            <span id="result-score-badge"
              class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold border mb-4"></span>
            <p class="text-slate-500 text-sm leading-relaxed max-w-[260px] mx-auto sm:mx-0 lg:mx-auto">
              Puntaje global de tu presencia digital: Google, publicidad, conversiones, medición y mensaje.
            </p>
          </div>
        </div>

        <!-- ── Col der: barras de desglose ── -->
        <!-- id="sec-areas" acá: en mobile queda DEBAJO del anillo (scroll real);
             en desktop ya está visible al lado, el scroll spy lo detecta en viewport -->
        <div id="sec-areas" class="lg:border-l lg:border-slate-800 lg:pl-10">
