  <!-- ═══════════════════════════════════════════════════════════════════════
       JAVASCRIPT — State machine + API + Rendering
  ═══════════════════════════════════════════════════════════════════════════ -->
  <script>
    'use strict';

    // ── Estado global ──────────────────────────────────────────────────────
    let currentUrl = '';

    // ── Utilidades de pantalla ─────────────────────────────────────────────
    function showScreen(id) {
      document.querySelectorAll('.screen').forEach(s => s.classList.add('hidden'));
      const target = document.getElementById(`screen-${id}`);
      target.classList.remove('hidden');
      // Reiniciar animación de entrada
      target.querySelectorAll('.fade-up').forEach(el => {
        el.style.animation = 'none';
        // Forzar reflow para reiniciar la animación
        void el.offsetHeight;
        el.style.animation = '';
      });
      window.scrollTo({ top: 0, behavior: 'instant' });
      // Mostrar floating CTA solo en pantalla de resultados
      const floatingCta = document.getElementById('floating-cta');
      if (floatingCta) floatingCta.classList.toggle('cta-hidden', id !== 'results');
    }

    // ── Validación de URL ──────────────────────────────────────────────────
    function isValidUrl(str) {
      if (!str || !str.includes('.')) return false;
      try {
        new URL(str.startsWith('http') ? str : `https://${str}`);
        return true;
      } catch {
        return false;
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // PANTALLA 1 → 2
    // ────────────────────────────────────────────────────────────────────────
    document.getElementById('btn-analizar').addEventListener('click', () => {
      const urlInput = document.getElementById('landing-url');
      const errEl = document.getElementById('landing-error');
      const val = urlInput.value.trim();

      if (!isValidUrl(val)) {
        errEl.classList.remove('hidden');
        urlInput.focus();
        return;
      }
      errEl.classList.add('hidden');
      currentUrl = val;
      document.getElementById('form-url-display').textContent = val;
      showScreen('form');
    });

    // Enter en el input de URL
    document.getElementById('landing-url').addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('btn-analizar').click();
    });

    document.getElementById('btn-back-landing').addEventListener('click', () => showScreen('landing'));

    // ────────────────────────────────────────────────────────────────────────
    // PANTALLA 2 → 3: envío del form
    // ────────────────────────────────────────────────────────────────────────
    document.getElementById('lead-form').addEventListener('submit', async e => {
      e.preventDefault();
      const nombre = document.getElementById('input-nombre').value.trim();
      const email  = document.getElementById('input-email').value.trim();
      const empresa = document.getElementById('input-empresa').value.trim();
      const errEl = document.getElementById('form-error');

      if (!nombre || !email || !empresa) {
        errEl.classList.remove('hidden');
        return;
      }
      errEl.classList.add('hidden');

      showScreen('loading');
      resetSteps();

      await runAnalysis({ url: currentUrl, nombre, email, empresa });
    });

    // ────────────────────────────────────────────────────────────────────────
    // LOADING STEPS
    // ────────────────────────────────────────────────────────────────────────
    function resetSteps() {
      document.getElementById('loading-error').classList.add('hidden');
      for (let i = 1; i <= 4; i++) setStep(i, 'pending');
    }

    /** state: 'pending' | 'active' | 'done' */
    function setStep(n, state) {
      const el = document.getElementById(`step-${n}`);
      const pending = el.querySelector('.step-pending');
      const active  = el.querySelector('.step-active');
      const done    = el.querySelector('.step-done');

      // Reset classes
      [pending, active, done].forEach(x => x.classList.add('hidden'));
      el.classList.remove(
        'border-indigo-500/30', 'bg-indigo-500/5',
        'border-emerald-500/20', 'bg-emerald-500/5'
      );

      if (state === 'pending') {
        pending.classList.remove('hidden');
      } else if (state === 'active') {
        active.classList.remove('hidden');
        el.classList.add('border-indigo-500/30', 'bg-indigo-500/5');
      } else if (state === 'done') {
        done.classList.remove('hidden');
        el.classList.add('border-emerald-500/20', 'bg-emerald-500/5');
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // LLAMADA A LA API con lectura de SSE
    // ────────────────────────────────────────────────────────────────────────
    async function runAnalysis(data) {
      try {
        const res = await fetch('/api/analyze', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (!res.ok || !res.body) {
          throw new Error(`El servidor respondió con error ${res.status}.`);
        }

        const reader  = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });

          // SSE: los mensajes están separados por \n\n
          const parts = buffer.split('\n\n');
          buffer = parts.pop(); // último fragmento incompleto, lo guardamos

          for (const part of parts) {
            if (!part.trim()) continue;

            let eventType = 'message';
            let eventData = '';

            for (const line of part.split('\n')) {
              if (line.startsWith('event: ')) eventType = line.slice(7).trim();
              if (line.startsWith('data: '))  eventData = line.slice(6).trim();
            }

            if (!eventData) continue;

            try {
              handleEvent(eventType, JSON.parse(eventData));
            } catch {
              console.warn('[SSE] No se pudo parsear:', eventData);
            }
          }
        }
      } catch (err) {
        showLoadingError(err.message ?? 'Error de conexión. Verificá tu internet.');
      }
    }

    function handleEvent(type, data) {
      if (type === 'progress') {
        // Marcar pasos anteriores como done, el actual como active
        for (let i = 1; i < data.step; i++) setStep(i, 'done');
        setStep(data.step, 'active');

      } else if (type === 'result') {
        // Completar todos los pasos y mostrar resultados
        for (let i = 1; i <= 4; i++) setStep(i, 'done');
        // Pequeña pausa para que el usuario vea el ✓ del último paso
        setTimeout(() => renderResults(data), 700);

      } else if (type === 'error') {
        showLoadingError(data.message ?? 'Error desconocido.');
      }
    }

    function showLoadingError(msg) {
      document.getElementById('loading-error').classList.remove('hidden');
      document.getElementById('loading-error-msg').textContent = msg;
    }

    document.getElementById('btn-retry').addEventListener('click', () => showScreen('landing'));

    // ────────────────────────────────────────────────────────────────────────
    // RENDERIZADO DE RESULTADOS
    // ────────────────────────────────────────────────────────────────────────
    function renderResults(data) {
      // URL y número
      document.getElementById('result-url').textContent = currentUrl;
      document.getElementById('result-score').textContent = data.growthScore;

      // ── SVG Ring: animamos dashoffset y color según score ───────────────
      // Circunferencia = 2π × r(50) = 314.159
      const CIRC = 314.159;
      const arc  = document.getElementById('score-arc');
      const targetOffset = CIRC * (1 - data.growthScore / 100);
      // Necesitamos dos rAF para que la transición CSS sea visible
      // (el browser debe pintar el estado inicial dashoffset=CIRC primero)
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          arc.style.strokeDashoffset = targetOffset;
          arc.style.stroke = scoreColor(data.growthScore);
          document.getElementById('score-ring-wrap').style.filter =
            `drop-shadow(0 0 16px ${scoreGlow(data.growthScore)})`;
        });
      });

      // ── Badge de nivel ────────────────────────────────────────────────────
      const badge = document.getElementById('result-score-badge');
      const { text, cls } = scoreBadge(data.growthScore);
      badge.textContent = text;
      badge.className = `inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold border ${cls}`;

      // ── Sub-scores con objetivo de referencia ────────────────────────────
      // TARGET: 17/20 = nivel de empresa que escala bien (85% de la barra)
      const TARGET     = 17;
      const TARGET_PCT = Math.round((TARGET / 20) * 100); // 85

      const subDefs = [
        { key: 'seo',           label: 'Posicionamiento en Google', icon: '🔍' },
        { key: 'paidReadiness', label: 'Preparación para publicidad', icon: '💰' },
        { key: 'cro',           label: 'Conversión de visitas',       icon: '🎯' },
        { key: 'tracking',      label: 'Medición de resultados',      icon: '📊' },
        { key: 'mensaje',       label: 'Claridad del mensaje',        icon: '✍️'  },
      ];

      const subContainer = document.getElementById('subscores-container');
      subContainer.innerHTML = subDefs.map(({ key, label, icon }) => {
        const score   = data.scores?.[key] ?? 0;
        const pct     = Math.round((score / 20) * 100);
        const gap     = TARGET - score;
        const isLarge = gap >= 5; // brecha grande = oportunidad destacada

        // Umbrales sobre 20: rojo 0-8, naranja 9-13, verde 14-20
        const isRed    = score <= 8;
        const isAmber  = score >= 9 && score <= 13;
        const isGreen  = score >= 14;

        const barHex = isGreen ? '#10b981' : isAmber ? '#f59e0b' : '#ef4444';
        const numCls = isGreen ? 'text-emerald-400' : isAmber ? 'text-amber-400' : 'text-red-400';

        // Texto de brecha debajo de la barra
        const gapText = score >= TARGET
          ? `<span class="text-[11px] text-emerald-500/70">En el nivel objetivo</span>`
          : `<span class="text-[11px] text-slate-600">Estás en ${score} · el objetivo es ${TARGET}/20</span>`;

        // Badge: solo en rojo es urgente; en naranja neutro; en verde positivo
        const bigGapBadge = isRed
          ? `<span class="text-[11px] text-red-400 font-semibold whitespace-nowrap">Mayor margen de mejora ↑</span>`
          : isAmber
          ? `<span class="text-[11px] text-amber-500/70 whitespace-nowrap">Hay margen</span>`
          : isGreen && score >= TARGET
          ? `<span class="text-[11px] text-emerald-500/70 whitespace-nowrap">Vas bien ✓</span>`
          : '';

        return `
          <div>
            <!-- Fila superior: nombre + puntaje -->
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-slate-300 flex items-center gap-2">
                <span class="text-base leading-none">${icon}</span>${escHtml(label)}
              </span>
              <span class="text-sm font-bold tabular-nums ${numCls}">
                ${score}<span class="text-slate-600 font-normal text-xs">/20</span>
              </span>
            </div>

            <!-- Barra + marca de objetivo -->
            <!-- py-[3px] da espacio para que el marcador sobresalga del track -->
            <div class="relative py-[3px] mb-1.5">
              <!-- Track con la barra de relleno -->
              <div class="h-2 bg-slate-800 rounded-full overflow-hidden">
                <div class="score-bar h-full rounded-full"
                     style="width:0%;background-color:${barHex}"
                     data-target="${pct}"></div>
              </div>
              <!-- Marca de objetivo en ${TARGET_PCT}% — línea vertical que sobresale -->
              <div class="absolute top-1/2 -translate-y-1/2 w-[2px] h-[14px]
                          rounded-full bg-slate-400/50 pointer-events-none"
                   style="left:${TARGET_PCT}%"
                   title="Objetivo: ${TARGET}/20"></div>
            </div>

            <!-- Fila inferior: texto brecha + badge oportunidad -->
            <div class="flex items-center justify-between gap-2 flex-wrap">
              ${gapText}
              ${bigGapBadge}
            </div>
          </div>
        `;
      }).join('');

      // ── Tarjetas de oportunidades ─────────────────────────────────────────
      const opContainer = document.getElementById('oportunidades-container');
      opContainer.innerHTML = (data.oportunidades ?? []).slice(0, 3).map((op, i) => {
        const num = String(i + 1).padStart(2, '0');
        return `
          <div class="bg-[#0C1220] border border-slate-700/50
                      hover:border-slate-600/70 hover:bg-[#0e1628]
                      rounded-2xl p-5 sm:p-6 transition-all duration-200">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-11 h-11 rounded-xl
                          bg-orange-500/10 border border-orange-500/20
                          flex items-center justify-center">
                <span class="text-orange-400 font-black text-lg leading-none">${num}</span>
              </div>
              <div class="flex-1 min-w-0 pt-0.5">
                <h4 class="font-bold text-white text-[15px] mb-2 leading-snug">
                  ${escHtml(op.titulo ?? '')}
                </h4>
                <p class="text-slate-400 text-sm leading-relaxed">
                  ${escHtml(op.detalle ?? '')}
                </p>
              </div>
            </div>
          </div>
        `;
      }).join('');

      // ── Bloque de cierre dinámico ─────────────────────────────────────────
      // Cuenta áreas en rojo (≤8) o naranja (9-13) para personalizar el mensaje
      const scores = data.scores ?? {};
      const weakCount = Object.values(scores).filter(s => s <= 13).length;
      const agendaHeading = document.getElementById('agenda-heading');
      const agendaBody    = document.getElementById('agenda-body');
      if (agendaHeading && agendaBody) {
        if (weakCount >= 3) {
          agendaHeading.textContent = 'Estas oportunidades se pueden trabajar';
          agendaBody.innerHTML =
            `Tu presencia digital tiene <strong class="text-white">${weakCount} áreas con margen de mejora</strong>. ` +
            `En una reunión de 20 minutos te mostramos por dónde empezar y cómo priorizarlas ` +
            `para conseguir más clientes — sin compromiso.`;
        } else if (weakCount >= 1) {
          agendaHeading.textContent = 'Hay margen para crecer';
          agendaBody.innerHTML =
            `Detectamos <strong class="text-white">${weakCount} área${weakCount > 1 ? 's' : ''} con margen de mejora</strong> ` +
            `en tu presencia digital. En 20 minutos te explicamos cómo trabajarlas ` +
            `para convertirlas en más clientes — sin compromiso.`;
        } else {
          agendaHeading.textContent = 'Tu presencia digital está en buen nivel';
          agendaBody.innerHTML =
            `Ya estás bien posicionado. En una reunión de 20 minutos te mostramos ` +
            `cómo llevar cada área al tope y qué acciones generan mayor retorno ahora mismo.`;
        }
      }

      renderAds(data.ads);
      showScreen('results');
      initScrollSpy();

      // Animar barras DESPUÉS del primer frame pintado
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          document.querySelectorAll('.score-bar[data-target]').forEach(bar => {
            bar.style.width = bar.dataset.target + '%';
          });
        });
      });
    }

    // ────────────────────────────────────────────────────────────────────────
    // TARJETA DE PUBLICIDAD EN META
    // ────────────────────────────────────────────────────────────────────────
    function renderAds(ads) {
      const container = document.getElementById('ads-container');
      if (!container) return;

      // Fallback si el campo viene undefined (análisis anteriores sin este dato)
      if (!ads || !ads.adLibraryUrl) {
        container.innerHTML = '';
        return;
      }

      const { searchTerm, adLibraryUrl, adCount, detected } = ads;

      let statusColor, statusDot, statusText, ctaText, borderCls;

      if (detected === true) {
        const n = adCount != null ? adCount : '?';
        statusDot   = '#22c55e';
        statusColor = 'text-emerald-400';
        borderCls   = 'border-emerald-500/20';
        statusText  = adCount != null
          ? `Detectamos <strong class="text-white">${n} anuncio${n === 1 ? '' : 's'} activo${n === 1 ? '' : 's'}</strong> en la biblioteca pública de Meta.`
          : `Detectamos anuncios activos en la biblioteca pública de Meta.`;
        ctaText     = 'Ver sus anuncios en Meta →';
      } else if (detected === false) {
        statusDot   = '#ef4444';
        statusColor = 'text-slate-400';
        borderCls   = 'border-slate-700/50';
        statusText  = `No detectamos anuncios activos en la búsqueda pública de Meta para <strong class="text-white">"${escHtml(searchTerm)}"</strong>. Puede haber campañas con otra segmentación o en otros canales.`;
        ctaText     = 'Verificar en Ad Library →';
      } else {
        statusDot   = '#64748b';
        statusColor = 'text-slate-500';
        borderCls   = 'border-slate-700/50';
        statusText  = `No pudimos verificar la presencia de anuncios desde la búsqueda pública de Meta para <strong class="text-white">"${escHtml(searchTerm)}"</strong>.`;
        ctaText     = 'Ver en Ad Library →';
      }

      container.innerHTML = `
        <div class="bg-[#0C1220] border ${borderCls}
                    rounded-2xl p-5 sm:p-6">
          <div class="flex items-start gap-4">
            <!-- Ícono Meta -->
            <div class="flex-shrink-0 w-11 h-11 rounded-xl
                        bg-blue-500/10 border border-blue-500/20
                        flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-400" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.989C18.343 21.129 22 16.99 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
            </div>

            <div class="flex-1 min-w-0">
              <!-- Status row -->
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full flex-shrink-0"
                      style="background-color:${statusDot}"></span>
                <span class="text-[11px] font-bold uppercase tracking-widest ${statusColor}">
                  Meta Ad Library
                </span>
              </div>

              <p class="text-slate-400 text-sm leading-relaxed mb-4">
                ${statusText}
              </p>

              <a href="${escHtml(adLibraryUrl)}"
                 target="_blank"
                 rel="noopener"
                 class="inline-flex items-center gap-2
                        text-xs font-bold text-blue-400 hover:text-blue-300
                        border border-blue-500/25 hover:border-blue-400/40
                        bg-blue-500/8 hover:bg-blue-500/12
                        px-4 py-2 rounded-lg transition-all duration-150">
                ${ctaText}
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      `;
    }

    /** Color del arco SVG según score global */
    function scoreColor(score) {
      if (score >= 71) return '#22c55e'; // verde
      if (score >= 41) return '#f97316'; // naranja
      return '#ef4444';                  // rojo
    }

    /** Glow del drop-shadow alrededor del anillo */
    function scoreGlow(score) {
      if (score >= 71) return 'rgba(34,197,94,0.28)';
      if (score >= 41) return 'rgba(249,115,22,0.28)';
      return 'rgba(239,68,68,0.28)';
    }

    function scoreBadge(score) {
      if (score >= 71) return { text: '✓ Buen rendimiento',           cls: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' };
      if (score >= 41) return { text: '↑ Alto potencial de mejora',   cls: 'bg-amber-500/10   text-amber-400  border-amber-500/20'   };
      return                   { text: '! Oportunidades urgentes',     cls: 'bg-red-500/10     text-red-400    border-red-500/20'     };
    }

    // Sanitización básica para prevenir XSS en el HTML renderizado
    function escHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    // ────────────────────────────────────────────────────────────────────────
    // SCROLL SPY & NAV INTERNA
    // ────────────────────────────────────────────────────────────────────────
    let scrollSpyObserver = null;

    function initScrollSpy() {
      // Limpiar observer anterior si el usuario corre un segundo análisis
      if (scrollSpyObserver) scrollSpyObserver.disconnect();

      const sections = ['sec-resumen', 'sec-areas', 'sec-oportunidades', 'sec-publicidad', 'sec-agenda'];
      const navLinks = document.querySelectorAll('.results-nav-link');

      function setActiveLink(sectionId) {
        navLinks.forEach(link => {
          link.classList.toggle('is-active', link.dataset.section === sectionId);
        });
      }

      // Activar "Resumen" al inicio (primer sección siempre visible)
      setActiveLink('sec-resumen');

      // IntersectionObserver: activa el link cuando la sección entra en el
      // tercio superior del viewport (compensando el nav sticky de ~52px)
      scrollSpyObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) setActiveLink(entry.target.id);
          }
        },
        { rootMargin: '-52px 0px -50% 0px', threshold: 0 }
      );

      sections.forEach(id => {
        const el = document.getElementById(id);
        if (el) scrollSpyObserver.observe(el);
      });
    }

    // Smooth scroll al hacer click en links del nav de resultados
    document.querySelectorAll('.results-nav-link').forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault();
        const target = document.getElementById(link.dataset.section);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // Smooth scroll del floating CTA (móvil y desktop) hacia #sec-agenda
    document.addEventListener('click', e => {
      const link = e.target.closest('#floating-cta-link-mobile, #floating-cta-link-desktop');
      if (!link) return;
      e.preventDefault();
      const target = document.getElementById('sec-agenda');
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Reiniciar todo desde cero
    document.getElementById('btn-restart').addEventListener('click', () => {
      document.getElementById('landing-url').value = '';
      showScreen('landing');
    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FLOATING CTA — visible solo en pantalla de resultados
       Mobile: barra fija ancho completo abajo.
       Desktop: píldora fija abajo a la derecha.
  ═══════════════════════════════════════════════════════════════════════════ -->
  <div id="floating-cta" class="cta-hidden fixed bottom-0 left-0 right-0 z-40 pointer-events-none">
    <!-- Mobile bar (hasta sm) -->
    <div class="sm:hidden bg-[#0C1220]/98 backdrop-blur-sm border-t border-slate-700/60
                px-4 py-3 pointer-events-auto">
      <a id="floating-cta-link-mobile" href="https://cal.com/tomas-zimba/30min" target="_blank" rel="noopener"
         class="flex items-center justify-center gap-2
                bg-orange-500 hover:bg-orange-400 active:scale-[0.99]
                text-white font-bold py-3.5 rounded-xl
                transition-all duration-150 text-sm w-full
                shadow-lg shadow-orange-500/25">
        Agendá gratis con Zimba
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
    <!-- Desktop pill (sm+) -->
    <div class="hidden sm:flex justify-end px-8 pb-8 pointer-events-auto">
      <a id="floating-cta-link-desktop" href="https://cal.com/tomas-zimba/30min" target="_blank" rel="noopener"
         class="inline-flex items-center gap-2.5
                bg-orange-500 hover:bg-orange-400 active:scale-[0.98]
                text-white font-bold px-6 py-3.5 rounded-2xl
                transition-all duration-150 text-sm
                shadow-2xl shadow-orange-500/35 hover:shadow-orange-500/55
                hover:-translate-y-0.5">
        Agendá gratis con los especialistas de Zimba
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</body>
</html>
