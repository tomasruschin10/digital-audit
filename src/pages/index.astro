    </div>

    <!-- ── Contenido principal ── -->
    <!-- pb-28: espacio para que el sticky CTA no tape el final del informe -->
    <div class="max-w-[720px] lg:max-w-[1100px] mx-auto px-4 sm:px-6 pb-28">

      <!-- ════════════════════════════════════════════════════════════════
           ENCABEZADO DEL INFORME — nombre empresa + URL + fecha
      ════════════════════════════════════════════════════════════════════ -->
      <div id="result-header" class="mb-8 mt-2">
        <p class="text-[11px] font-bold uppercase tracking-widest text-gray-500 mb-1">
          Diagnóstico de presencia digital
