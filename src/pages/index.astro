                     font-black rounded-2xl transition-all duration-150 text-[15px] sm:text-base
                     active:scale-[0.98] hover:scale-[1.02] w-full sm:w-auto"
              style="background:#ffffff; color:#5b3df5; padding:18px 36px;"
            >
              Agendá gratis con los especialistas de Zimba
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24"
                   stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>

            <p class="text-xs mt-5" style="color:rgba(196,181,253,0.65);">
