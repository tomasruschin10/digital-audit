---
// index.astro — Lead magnet: auditoría digital automática
// Tres pantallas manejadas con vanilla JS (sin frameworks)
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Growth Audit — Diagnóstico integral de tu presencia digital</title>
  <meta name="description" content="Pegá la URL de tu empresa y en 60 segundos analizamos toda tu presencia digital: Google, publicidad en Meta, conversión y medición. Diagnóstico gratuito." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; }
    body { font-family: 'Inter', system-ui, sans-serif; }
    .screen.hidden { display: none !important; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) both; }

    /* SVG arc del Growth Score — transición animada desde vacío */
    #score-arc {
      transition: stroke-dashoffset 1.4s cubic-bezier(0.16, 1, 0.3, 1),
                  stroke 0.5s ease;
    }

    /* Barras de sub-scores */
    .score-bar { transition: width 1.1s cubic-bezier(0.16, 1, 0.3, 1); }

    /* Fondo del hero — glow multicapa para dar energía y profundidad */
    .hero-glow {
      background:
        radial-gradient(ellipse 70% 50% at 50% 100%,
          rgba(249,115,22,0.08) 0%,
          transparent 65%),
        radial-gradient(ellipse 90% 60% at 50% 30%,
          rgba(99,102,241,0.13) 0%,
          transparent 70%);
    }

    /* Línea de acento horizontal debajo del badge */
    .hero-accent-line {
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(249,115,22,0.5) 30%,
        rgba(99,102,241,0.5) 70%,
        transparent 100%);
    }

    /* Separadores de sección en resultados */
    .section-divider { border-top: 1px solid rgba(255,255,255,0.06); }

    /* Scroll margin: los anchors quedan por debajo del nav sticky (~48px) */
    [id^="sec-"] { scroll-margin-top: 52px; }

    /* Nav interna de resultados */
    .results-nav-link {
      transition: color 0.15s ease, background-color 0.15s ease;
    }
    .results-nav-link.is-active {
      color: #ffffff;
      background-color: rgba(255, 255, 255, 0.07);
    }

    /* Floating CTA — visibilidad controlada con .cta-hidden */
    #floating-cta { transition: opacity 0.25s ease, visibility 0.25s; }
    .cta-hidden    { opacity: 0; visibility: hidden; }
  </style>
</head>
<body class="bg-[#060B14] text-white min-h-screen antialiased">

  <!-- ═══════════════════════════════════════════════════════════════════════
       PANTALLA 1 — LANDING
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section id="screen-landing" class="screen min-h-[100dvh] flex flex-col">

    <!-- Nav -->
    <nav class="px-5 py-4 flex items-center justify-between max-w-5xl mx-auto w-full">
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-lg bg-indigo-600 flex items-center justify-center shadow-lg shadow-indigo-500/30">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <span class="font-bold text-sm tracking-tight">GrowthAudit</span>
      </div>
      <span class="text-xs text-slate-500 hidden sm:block">
        Una herramienta de <span class="text-slate-300 font-medium">tu agencia</span>
      </span>
    </nav>

    <!-- Hero -->
    <div class="hero-glow flex-1 flex flex-col items-center justify-center
                px-5 py-6 sm:py-10 text-center">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2.5
                  bg-gradient-to-r from-indigo-500/10 to-orange-500/10
                  border border-white/10
                  rounded-full px-4 py-1.5 text-xs font-semibold mb-2 sm:mb-3
                  text-slate-300 tracking-wide">
        <span class="w-1.5 h-1.5 rounded-full bg-orange-400 animate-pulse block flex-shrink-0"></span>
        Diagnóstico de presencia digital · 60 segundos · Sin registro
      </div>

      <!-- Línea de acento decorativa -->
      <div class="hero-accent-line w-24 h-[2px] rounded-full mb-4 sm:mb-5 opacity-70"></div>

      <!-- H1 — mobile: 1.35rem con quiebres manuales para evitar líneas sueltas -->
      <h1 class="text-[1.35rem] sm:text-[2.4rem] md:text-[2.875rem] font-black leading-[1.15] sm:leading-[1.1] tracking-tight w-full max-w-[62rem] mb-2 sm:mb-3">
        Tu negocio puede<br class="sm:hidden" /> vender más.<br />
        <span class="bg-gradient-to-r from-orange-400 via-amber-400 to-orange-300 bg-clip-text text-transparent">
          Te mostramos<br class="sm:hidden" /> exactamente cómo.
        </span>
      </h1>

      <!-- Subtítulo -->
      <p class="text-slate-400 text-sm sm:text-base max-w-xl mb-5 sm:mb-6 leading-snug">
        Pegá tu URL y analizamos toda tu presencia digital: Google, publicidad, conversión y medición.
      </p>

      <!-- URL Input + CTA — ELEMENTO PRINCIPAL -->
      <div class="w-full max-w-[600px]">
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="relative flex-1">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
              </svg>
            </span>
            <input
              id="landing-url"
              type="url"
              inputmode="url"
              placeholder="tuempresa.com"
              autocomplete="url"
              class="w-full h-[60px] bg-slate-800/80 border border-slate-700/70
                     rounded-2xl pl-12 pr-4 text-white placeholder-slate-500
                     focus:outline-none focus:border-indigo-500/80 focus:ring-2 focus:ring-indigo-500/25
                     transition text-[16px]"
            />
          </div>
          <button
            id="btn-analizar"
            class="h-[60px] bg-orange-500 hover:bg-orange-400 active:scale-[0.98]
                   text-white font-black px-8 rounded-2xl transition-all duration-150
                   whitespace-nowrap text-[15px] tracking-tight
                   shadow-xl shadow-orange-500/35 hover:shadow-orange-500/55
                   hover:-translate-y-0.5 sm:w-auto w-full"
          >
            Mostrame mis oportunidades →
          </button>
        </div>
        <p id="landing-error" class="text-red-400 text-xs mt-2.5 hidden text-left pl-1">
          Ingresá una URL válida (ej: tuempresa.com)
        </p>
      </div>

      <!-- Social proof -->
      <div class="mt-4 sm:mt-7 flex flex-col sm:flex-row items-center gap-3 text-sm text-slate-500">
        <div class="flex -space-x-2">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-pink-400 to-rose-600 border-2 border-[#060B14] flex items-center justify-center text-xs font-bold text-white">M</div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-400 to-indigo-600 border-2 border-[#060B14] flex items-center justify-center text-xs font-bold text-white">J</div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-400 to-teal-600 border-2 border-[#060B14] flex items-center justify-center text-xs font-bold text-white">S</div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-amber-400 to-orange-600 border-2 border-[#060B14] flex items-center justify-center text-xs font-bold text-white">R</div>
        </div>
        <span>Más de <strong class="text-slate-300">200 empresas</strong> ya analizaron su sitio</span>
      </div>
    </div>

    <!-- Footer strip -->
    <div class="border-t border-slate-800/60 py-4 px-5">
      <div class="max-w-4xl mx-auto flex flex-wrap items-center justify-center gap-3 sm:gap-6 text-xs text-slate-600">
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-orange-500 block"></span>Publicidad paga</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-indigo-500 block"></span>Posicionamiento en Google</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 block"></span>Captación de leads</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-violet-500 block"></span>Conversión de visitas</span>
        <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-amber-500 block"></span>Mensaje y propuesta</span>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       PANTALLA 2 — MINI-FORM (captura del lead)
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section id="screen-form" class="screen hidden min-h-screen flex flex-col items-center justify-center px-5 py-16">
    <div class="w-full max-w-md fade-up">

      <!-- Volver -->
      <button id="btn-back-landing" class="flex items-center gap-1.5 text-slate-500 hover:text-white text-sm mb-8 transition-colors group">
        <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Volver
      </button>

      <!-- URL seleccionada -->
      <div class="bg-slate-800/50 border border-slate-700/50 rounded-xl px-4 py-3 flex items-center gap-3 mb-8">
        <div class="w-8 h-8 rounded-lg bg-indigo-500/15 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
          </svg>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-[11px] text-slate-500 mb-0.5 uppercase tracking-wider">Vamos a analizar</p>
          <p id="form-url-display" class="text-sm font-semibold text-white truncate"></p>
        </div>
        <span class="text-[11px] bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 rounded-full px-2.5 py-0.5 font-medium flex-shrink-0">Lista</span>
      </div>

      <!-- Título -->
      <h2 class="text-2xl sm:text-3xl font-black mb-2">Un paso más</h2>
      <p class="text-slate-400 text-sm mb-7 leading-relaxed">
        Te mostramos el informe ahora mismo y te explicamos qué significa para tu negocio.
      </p>

      <!-- Form -->
      <form id="lead-form" novalidate class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5" for="input-nombre">
            Nombre completo
          </label>
          <input
            id="input-nombre" type="text" name="nombre" placeholder="Juan García"
            autocomplete="name" required
            class="w-full h-12 bg-slate-800/70 border border-slate-700/60 rounded-xl px-4 text-white placeholder-slate-500 focus:outline-none focus:border-indigo-500/70 focus:ring-2 focus:ring-indigo-500/20 transition text-sm"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5" for="input-email">
            Email de trabajo
          </label>
          <input
            id="input-email" type="email" name="email" placeholder="juan@tuempresa.com"
            autocomplete="email" required
            class="w-full h-12 bg-slate-800/70 border border-slate-700/60 rounded-xl px-4 text-white placeholder-slate-500 focus:outline-none focus:border-indigo-500/70 focus:ring-2 focus:ring-indigo-500/20 transition text-sm"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1.5" for="input-empresa">
            Empresa
          </label>
          <input
            id="input-empresa" type="text" name="empresa" placeholder="Acme SA"
            autocomplete="organization" required
            class="w-full h-12 bg-slate-800/70 border border-slate-700/60 rounded-xl px-4 text-white placeholder-slate-500 focus:outline-none focus:border-indigo-500/70 focus:ring-2 focus:ring-indigo-500/20 transition text-sm"
          />
        </div>

        <p id="form-error" class="text-red-400 text-xs hidden pt-1">
          Completá todos los campos para continuar.
        </p>

        <button
          type="submit"
          class="w-full h-13 bg-orange-500 hover:bg-orange-400 active:scale-[0.98] text-white font-bold py-4 rounded-xl transition-all duration-150 text-sm shadow-lg shadow-orange-500/25 hover:shadow-orange-500/40 mt-1"
        >
          Ver mi Growth Score →
        </button>

        <p class="text-center text-xs text-slate-600 pt-1">
          Sin spam. Tu info no se comparte con terceros.
        </p>
      </form>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       PANTALLA 3 — LOADING con pasos reales
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section id="screen-loading" class="screen hidden min-h-screen flex flex-col items-center justify-center px-5 py-16">
    <div class="w-full max-w-sm text-center fade-up">

      <!-- Ícono animado -->
      <div class="w-16 h-16 rounded-2xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mx-auto mb-7">
        <svg class="w-8 h-8 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-20" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-80" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </div>

      <h2 class="text-xl font-bold mb-1.5">Analizando tu presencia digital</h2>
      <p class="text-slate-500 text-sm mb-9">Puede tardar hasta 30 segundos</p>

      <!-- Steps — estado manejado por JS -->
      <div class="space-y-2.5 text-left" id="steps-container">

        <!-- Cada step tiene 3 íconos: pending (dot), active (spinner), done (check) -->
        <!-- step-pending → visibles por defecto, el resto hidden -->

        <div id="step-1" class="loading-step flex items-center gap-3 p-3 rounded-xl border border-transparent transition-all duration-400">
          <div class="w-7 h-7 flex items-center justify-center flex-shrink-0">
            <span class="step-pending w-2 h-2 rounded-full bg-slate-600 block"></span>
            <svg class="step-active hidden w-4 h-4 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            <svg class="step-done hidden w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <span class="text-sm text-slate-400 step-label">Analizando tu sitio y tu marca</span>
        </div>

        <div id="step-2" class="loading-step flex items-center gap-3 p-3 rounded-xl border border-transparent transition-all duration-400">
          <div class="w-7 h-7 flex items-center justify-center flex-shrink-0">
            <span class="step-pending w-2 h-2 rounded-full bg-slate-600 block"></span>
            <svg class="step-active hidden w-4 h-4 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            <svg class="step-done hidden w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <span class="text-sm text-slate-400 step-label">Revisando publicidad y medición</span>
        </div>

        <div id="step-3" class="loading-step flex items-center gap-3 p-3 rounded-xl border border-transparent transition-all duration-400">
          <div class="w-7 h-7 flex items-center justify-center flex-shrink-0">
            <span class="step-pending w-2 h-2 rounded-full bg-slate-600 block"></span>
            <svg class="step-active hidden w-4 h-4 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            <svg class="step-done hidden w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <span class="text-sm text-slate-400 step-label">Evaluando posicionamiento en Google</span>
        </div>

        <div id="step-4" class="loading-step flex items-center gap-3 p-3 rounded-xl border border-transparent transition-all duration-400">
          <div class="w-7 h-7 flex items-center justify-center flex-shrink-0">
            <span class="step-pending w-2 h-2 rounded-full bg-slate-600 block"></span>
            <svg class="step-active hidden w-4 h-4 text-indigo-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            <svg class="step-done hidden w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <span class="text-sm text-slate-400 step-label">Armando el panorama completo de tu marca</span>
        </div>
      </div>

      <!-- Error state -->
      <div id="loading-error" class="hidden mt-8 p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-left">
        <p class="text-red-400 text-sm font-semibold mb-1">No pudimos analizar el sitio</p>
        <p id="loading-error-msg" class="text-red-300/60 text-xs leading-relaxed mb-3"></p>
        <button id="btn-retry" class="text-xs text-indigo-400 hover:text-indigo-300 transition-colors">
          ← Intentar con otra URL
        </button>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       PANTALLA 4 — RESULTADOS
       Mobile: columna única + nav sticky + floating CTA bar abajo.
       Desktop: 2 cols arriba (anillo | barras), grilla de 3 oportunidades,
       floating pill abajo a la derecha.
  ═══════════════════════════════════════════════════════════════════════════ -->
  <section id="screen-results" class="screen hidden">

    <!-- ── Mini nav (URL + restart) ── -->
    <div class="max-w-[720px] lg:max-w-[1100px] mx-auto px-4 sm:px-6 pt-8 sm:pt-10 mb-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2 min-w-0">
          <svg class="w-3.5 h-3.5 text-slate-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9" />
          </svg>
          <span id="result-url" class="text-sm text-slate-500 truncate max-w-[180px] sm:max-w-xs lg:max-w-sm"></span>
        </div>
        <button id="btn-restart"
          class="text-xs text-slate-500 hover:text-indigo-400 transition-colors flex-shrink-0 ml-4 font-semibold">
          ← Nuevo análisis
        </button>
      </div>
    </div>

    <!-- ── Nav interna sticky (se pega arriba al scrollear) ── -->
    <!-- Fondo con blur para que el contenido no se "mezcle" al pasar por debajo -->
    <nav id="results-nav"
         class="sticky top-0 z-30 bg-[#060B14]/95 backdrop-blur border-b border-slate-800/60">
      <div class="max-w-[720px] lg:max-w-[1100px] mx-auto px-4 sm:px-6">
        <div class="flex items-center gap-0.5 py-2">
          <a href="#sec-resumen" data-section="sec-resumen"
             class="results-nav-link text-xs font-semibold text-slate-500 hover:text-white
                    px-3 py-1.5 rounded-lg cursor-pointer">
            Resumen
          </a>
          <a href="#sec-areas" data-section="sec-areas"
             class="results-nav-link text-xs font-semibold text-slate-500 hover:text-white
                    px-3 py-1.5 rounded-lg cursor-pointer">
            Áreas
          </a>
          <a href="#sec-oportunidades" data-section="sec-oportunidades"
             class="results-nav-link text-xs font-semibold text-slate-500 hover:text-white
                    px-3 py-1.5 rounded-lg cursor-pointer">
            Oportunidades
          </a>
          <a href="#sec-publicidad" data-section="sec-publicidad"
             class="results-nav-link text-xs font-semibold text-slate-500 hover:text-white
