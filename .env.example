# Requerido — conseguilo en https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Opcional — si lo definís, el scraper usa Firecrawl como fallback
# para sitios que bloquean el fetch directo (JS-heavy, bot-protected, etc.)
FIRECRAWL_API_KEY=fc-...

# Notificaciones de leads por email (Resend — https://resend.com)
# Sin estas variables las notificaciones están desactivadas (no rompe nada).
RESEND_API_KEY=re_...
NOTIFY_EMAIL=tu@email.com        # adónde querés recibir los avisos
FROM_EMAIL=leads@tudominio.com   # debe ser un dominio verificado en Resend (o usar onboarding@resend.dev en modo test)
